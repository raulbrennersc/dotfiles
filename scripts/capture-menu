#!/usr/bin/env bash
options="ůįĄÄ  Color Picker\nůįĄĄ  Screenshot (Region)\nůįĻĎ  Screenshot (Full)\nůįĎč  Record Screen"
chosen=$(echo -e "$options" | walker --dmenu | xargs)

case "$chosen" in
    "ůįĄÄ Color Picker") hyprpicker -a ;;
    "ůįĄĄ Screenshot (Region)") hyprshot -m region ;;
    "ůįĻĎ Screenshot (Full)") hyprshot -m output ;;
    "ůįĎč Record Screen") 
        gpu-screen-recorder -w $(hyprctl activewindow -j | jq -r .address) \
        -f 60 -a "default_output" -o ~/Videos/rec_$(date +%d%b_%H%M).mp4 ;;
esac
