#!/usr/bin/env bash

current=$(powerprofilesctl get)

options="箚뱟  Performance\n箚푷  Balanced\n箚푺  Power-saver"

chosen=$(echo -e "$options" | walker --dmenu --placeholder "Current: $current" | xargs)

case "$chosen" in
    "箚뱟 Performance")
        powerprofilesctl set performance
        notify-send "Power Profile" "Switched to Performance" -i high-priority
        ;;
    "箚푷 Balanced")
        powerprofilesctl set balanced
        notify-send "Power Profile" "Switched to Balanced" -i battery
        ;;
    "箚푺 Power-saver")
        powerprofilesctl set power-saver
        notify-send "Power Profile" "Switched to Power-saver" -i battery-caution
        ;;
esac
