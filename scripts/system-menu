#!/usr/bin/env bash

# Define options with icons
options="ůįź•  Shutdown\nůįĎź  Reboot\nůį§Ą  Suspend\nůįćÉ  Logout\nůįóľ  Lock"

# Open Walker in dmenu mode
chosen=$(echo -e "$options" | walker --dmenu --placeholder "System Action" | xargs)

case "$chosen" in
    "ůįź• Shutdown") systemctl poweroff ;;
    "ůįĎź Reboot") systemctl reboot ;;
    "ůį§Ą Suspend") systemctl suspend ;;
    "ůįćÉ Logout") hyprctl dispatch exit ;;
    "ůįóľ Lock") loginctl lock-session ;;
esac
